#!/bin/bash
# clipimg — 在 Docker 容器内运行
# 查看并管理 /workspace/.clip 目录下的剪贴板图片
#
# 用法：
#   clipimg           输出最新图片路径
#   clipimg list      列出所有图片
#   clipimg clean     清除7天前的旧图片

set -euo pipefail

CLIP_DIR="/workspace/.clip"
CMD="${1:-latest}"

check_dir() {
    if [ ! -d "$CLIP_DIR" ]; then
        echo "❌ $CLIP_DIR 不存在，请确认容器挂载了 Windows 工作目录到 /workspace"
        exit 1
    fi
}

case "$CMD" in
    latest|"")
        check_dir
        if [ -f "$CLIP_DIR/latest.png" ]; then
            echo "$CLIP_DIR/latest.png"
        else
            echo "❌ 暂无图片。请先在 Windows 里复制一张图，并确认 clipboard-watcher 守护进程在运行。"
            exit 1
        fi
        ;;

    list|ls)
        check_dir
        echo "📁 $CLIP_DIR 中的图片："
        find "$CLIP_DIR" -maxdepth 1 -name "clip_*.png" \
             -printf '  %Tc  %p\n' 2>/dev/null | sort || echo "  （空）"
        ;;

    clean)
        check_dir
        COUNT=$(find "$CLIP_DIR" -maxdepth 1 -name "clip_*.png" -mtime +7 | wc -l)
        find "$CLIP_DIR" -maxdepth 1 -name "clip_*.png" -mtime +7 -delete
        # latest.png 是实体文件，按时间重新指向最新留存的
        NEWEST=$(find "$CLIP_DIR" -maxdepth 1 -name "clip_*.png" \
                 -printf '%T@ %p\n' 2>/dev/null | sort -n | tail -1 | cut -d' ' -f2-)
        [ -n "$NEWEST" ] && cp -f "$NEWEST" "$CLIP_DIR/latest.png"
        echo "🗑️  已删除 $COUNT 个7天前的图片"
        ;;

    help|-h|--help)
        sed -n '2,8p' "$0" | sed 's/^# //'
        ;;

    *)
        echo "未知命令: $CMD"
        echo "用法: clipimg [latest|list|clean|help]"
        exit 1
        ;;
esac
